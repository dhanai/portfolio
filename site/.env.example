# Neon Postgres (pooled URL for Vercel/serverless)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Vercel Blob — public store for work preview uploads
# Standard names (default store):
# BLOB_READ_WRITE_TOKEN=""
# BLOB_STORE_ID=""
# Named store (e.g. "pubblob" in Vercel Storage):
# PUBBLOB_READ_WRITE_TOKEN=""
# PUBBLOB_STORE_ID=""

ADMIN_PASSWORD="change-me-in-production"
SESSION_SECRET="replace-with-32-char-random-secret!!"
